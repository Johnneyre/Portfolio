---
interface Props {
  variant?: 'default' | 'subtle';
}

const { variant = 'default' } = Astro.props;
const opacity = variant === 'subtle' ? '0.07' : '0.1';
const opacityAlt = variant === 'subtle' ? '0.05' : '0.08';
---

<!-- Right blob -->
<div
  class="blob pointer-events-none absolute -top-16 -right-24 w-80 h-80 rounded-full"
  style={`background: radial-gradient(circle, var(--color-brand-400), transparent 65%); opacity: ${opacity};`}
></div>

<!-- Left blob -->
<div
  class="blob-delay pointer-events-none absolute bottom-8 -left-28 w-72 h-72 rounded-full"
  style={`background: radial-gradient(circle, var(--color-brand-300), transparent 65%); opacity: ${opacityAlt};`}
></div>
