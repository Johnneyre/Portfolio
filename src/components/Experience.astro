---
import { TIMELINE_ITEMS } from '../data/portfolio';
import { useTranslations } from '../i18n/utils';
import type { SupportedLocale } from '../i18n/utils';
import DecorativeBlobs from './DecorativeBlobs.astro';
import Icon from './Icon.astro';

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  id="experience"
  class="relative section-padding overflow-hidden"
  style="background: var(--color-surface-950);"
>
  <DecorativeBlobs variant="subtle" />

  <div class="container-max relative z-10">

    <!-- Section header -->
    <div class="reveal mb-12">
      <p
        class="text-sm font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-brand-400);"
        data-i18n="experience.label"
      >
        {t.experience.label}
      </p>
      <h2 class="text-section-title" style="color: var(--color-text-primary);" data-i18n="experience.title">
        {t.experience.title}
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative pl-8">
      <!-- Vertical line -->
      <div
        class="absolute left-2.75 top-2 bottom-0 w-0.5"
        style="background: linear-gradient(to bottom, var(--color-brand-500), oklch(58% 0.18 155 / 0.08));"
      ></div>

      {TIMELINE_ITEMS.map((item, idx) => {
        const tItem = t.timeline_items[item.id as keyof typeof t.timeline_items];
        return (
          <div class={`reveal reveal-delay-${Math.min(idx + 1, 3)} relative mb-14 last:mb-0`}>

            <!-- Dot with icon -->
            <div
              class="timeline-dot"
              style="background: var(--color-brand-500);"
            >
              {item.type === 'work'
                ? <Icon name="briefcase" size={11} class="text-white" />
                : <Icon name="graduation" size={11} class="text-white" />
              }
            </div>

            <!-- Content -->
            <div class="ml-5">
              <!-- Role + company row -->
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-2 mb-1">
                <h3 class="text-lg font-bold m-0" style="color: var(--color-text-primary);">
                  <span data-i18n={`timeline_items.${item.id}.role`}>{tItem.role}</span>
                </h3>
                <span class="hidden sm:inline text-sm" style="color: var(--color-text-muted);">—</span>
                <span class="text-md font-semibold gradient-text">{item.company}</span>
              </div>

              <!-- Date below role -->
              <p
                class="text-sm mb-6 flex items-center gap-1.5 font-bold"
                style="color: var(--color-brand-400);"
              >
                <Icon name="calendar" size={12} />
                <span data-i18n={`timeline_items.${item.id}.period`}>{tItem.period}</span>
              </p>

              <!-- Bullets -->
              <ul
                class="list-none m-0 p-0 flex flex-col gap-3"
                data-i18n-bullets={`timeline_items.${item.id}.bullets`}
              >
                {tItem.bullets.map((bullet, bIdx) => (
                  <li
                    class={`reveal reveal-delay-${Math.min(bIdx + 1, 5)} card p-4 flex gap-3 items-start`}
                  >
                    <span
                      class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full"
                      style="background: var(--color-brand-400);"
                    ></span>
                    <p class="text-sm leading-relaxed m-0" style="color: var(--color-text-secondary);">
                      {bullet}
                    </p>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
