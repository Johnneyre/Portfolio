---
import { useTranslations, sectionId } from "../i18n/utils";
import type { SupportedLocale } from "../i18n/utils";

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<footer
  class="border-t"
  style="border-color: var(--color-surface-700); background: var(--color-surface-950);"
>
  <div class="container-max flex flex-col sm:flex-row items-center justify-between gap-4 py-7 px-5">
    <nav>
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        <li>
          <a href={`#${sectionId(locale, "home")}`} class="link-hover text-sm font-medium">
            {t.footer.links.home}
          </a>
        </li>
        <li>
          <a href={`#${sectionId(locale, "experience")}`} class="link-hover text-sm font-medium">
            {t.footer.links.experience}
          </a>
        </li>
        <li>
          <a href={`#${sectionId(locale, "projects")}`} class="link-hover text-sm font-medium">
            {t.footer.links.projects}
          </a>
        </li>
      </ul>
    </nav>

    <p class="text-sm m-0" style="color: var(--color-text-muted);">
      &copy; <span id="footer-year"></span> Johnneyre Zambrano
    </p>
  </div>
</footer>

<script>
  document.addEventListener("astro:page-load", () => {
    const el = document.getElementById("footer-year");
    if (el) el.textContent = new Date().getFullYear().toString();
  });
</script>
