---
import { useTranslations, getLocalePath } from "../i18n/utils";
import type { SupportedLocale } from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import LangSwitcher from "./LangSwitcher.astro";
import Icon from "./Icon.astro";

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<header class="header-glass sticky top-0 z-50 transition-shadow">
  <nav class="container-max flex items-center justify-between py-4 px-5">
    <!-- Logo -->
    <a href={getLocalePath(locale)} class="font-extrabold text-xl tracking-tight gradient-text"> JZ </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      <li>
        <a
          href="#experience"
          class="nav-link link-hover font-medium"
          data-i18n="nav.experience"
          style="font-size: 15.5px;"
        >
          {t.nav.experience}
        </a>
      </li>
      <li>
        <a
          href="#projects"
          class="nav-link link-hover font-medium"
          data-i18n="nav.projects"
          style="font-size: 15.5px;"
        >
          {t.nav.projects}
        </a>
      </li>
      <li>
        <a
          href="#skills"
          class="nav-link link-hover font-medium"
          data-i18n="nav.skills"
          style="font-size: 15.5px;"
        >
          {t.nav.skills}
        </a>
      </li>
    </ul>

    <!-- Right: lang switcher + theme toggle -->
    <div class="flex items-center gap-3">
      <LangSwitcher />
      <ThemeToggle />

      <!-- Mobile hamburger -->
      <label
        class="md:hidden cursor-pointer"
        for="mobile-menu-toggle"
        aria-label="Menú"
        style="color: var(--color-text-secondary);"
      >
        <Icon name="menu" size={22} />
      </label>
    </div>
  </nav>

  <!-- Mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="sr-only peer" />
  <div
    id="mobile-menu"
    class="flex flex-col gap-4 px-5 pt-2 pb-2 md:hidden border-t absolute top-full left-0 right-0 z-50 opacity-0 invisible -translate-y-2 transition-all duration-300 ease-in-out peer-checked:opacity-100 peer-checked:visible peer-checked:translate-y-0"
    style="border-color: var(--color-surface-700); background: var(--color-surface-900, var(--color-bg));"
  >
    <a href="#experience" class="nav-link link-hover font-medium py-1" data-i18n="nav.experience">
      {t.nav.experience}
    </a>
    <a href="#projects" class="nav-link link-hover font-medium py-1" data-i18n="nav.projects">
      {t.nav.projects}
    </a>
    <a href="#skills" class="nav-link link-hover font-medium py-1" data-i18n="nav.skills">
      {t.nav.skills}
    </a>
  </div>
</header>

<script>
  const header = document.querySelector(".header-glass") as HTMLElement | null;
  function updateHeader(): void {
    header?.classList.toggle("is-scrolled", window.scrollY > 40);
  }
  window.addEventListener("scroll", updateHeader, { passive: true });

  // Ensure header starts transparent on page load
  if (window.location.hash === "" || window.location.hash === "#inicio") {
    window.scrollTo(0, 0);
  }
  updateHeader();

  // Close mobile menu when a section link is clicked
  const menuToggle = document.getElementById("mobile-menu-toggle") as HTMLInputElement | null;
  const mobileMenu = document.getElementById("mobile-menu");
  if (menuToggle && mobileMenu) {
    const links = mobileMenu.querySelectorAll("a");
    links.forEach((link) => {
      link.addEventListener("click", () => {
        menuToggle.checked = false;
      });
    });
  }
</script>
