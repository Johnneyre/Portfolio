---
import { Image } from "astro:assets";
import perfilPhoto from "../assets/perfil_photo.jpg";
import { SOCIAL_LINKS } from "../data/portfolio";
import { useTranslations, sectionId } from "../i18n/utils";
import type { SupportedLocale } from "../i18n/utils";
import Icon from "./Icon.astro";

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const emailLink = SOCIAL_LINKS.find((l) => l.icon === "email")!;
const linkedinLink = SOCIAL_LINKS.find((l) => l.icon === "linkedin")!;
const githubLink = SOCIAL_LINKS.find((l) => l.icon === "github")!;
---

<section
  id={sectionId(locale, "home")}
  class="relative overflow-hidden"
  style="height: 100dvh; padding-inline: clamp(1.25rem, 5vw, 2rem); margin-top: calc(-1 * var(--header-height));"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-72"
    style="background: linear-gradient(to bottom, oklch(72% 0.16 155 / 0.18), transparent);"
    aria-hidden="true"
  >
  </div>

  <div
    class="flex items-center justify-center container-max relative z-10 pb-28 md:pb-20"
    style="height: 100%; padding-top: calc(var(--header-height) + 2rem);"
  >
    <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-8 md:gap-32">
      <div class="flex-1 text-center sm:text-left">
        <h1 class="text-hero mb-2" style="color: var(--color-text-primary);">
          <span>{t.hero.greeting}</span>&nbsp;<span class="gradient-text"
            >{t.owner.name.split(" ")[0]}</span
          >
        </h1>

        <p
          class="hero-enter-2 font-bold mb-3 gradient-text"
          style="font-size: clamp(1.35rem, 3vw, 1.75rem);"
        >
          {t.hero.role}
        </p>

        <p
          class="hero-enter-3 max-w-lg mx-auto sm:mx-0 mb-10 text-base leading-relaxed"
          style="color: var(--color-text-secondary);"
        >
          {t.hero.bio}
        </p>

        <div class="hero-enter-4 flex flex-wrap gap-3 justify-center sm:justify-start">
          <a
            href={linkedinLink.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.owner.name} en LinkedIn`}
            class="social-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border"
            style="border-color: var(--color-brand-500); background: oklch(95% 0.09 155 / 0.08); color: var(--color-text-primary);"
          >
            <Icon name="linkedin" size={16} aria-hidden="true" />
            LinkedIn
          </a>

          <a
            href={githubLink.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${t.owner.name} en GitHub`}
            class="social-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border"
            style="border-color: var(--color-brand-500); background: oklch(95% 0.09 155 / 0.08); color: var(--color-text-primary);"
          >
            <Icon name="github" size={16} aria-hidden="true" />
            GitHub
          </a>

          <a
            href={emailLink.href}
            aria-label={`Enviar email a ${t.owner.name}`}
            class="social-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border"
            style="border-color: var(--color-brand-500); background: oklch(95% 0.09 155 / 0.08); color: var(--color-text-primary);"
          >
            <Icon name="email" size={16} aria-hidden="true" />
            {t.social.email}
          </a>
        </div>
      </div>

      <div class="hero-enter-1 shrink-0 flex justify-center">
        <div
          class="relative w-52 h-52 md:w-64 md:h-64 rounded-full overflow-hidden"
          style="
            border: 3px solid oklch(58% 0.18 155 / 0.5);
            box-shadow: 0 0 40px oklch(58% 0.18 155 / 0.25), 0 0 0 8px oklch(58% 0.18 155 / 0.06);
          "
        >
          <Image
            src={perfilPhoto}
            alt={`${t.owner.name} – ${t.owner.role}`}
            class="w-full h-full object-cover"
            loading="eager"
            width={512}
            height={512}
            quality="high"
            format="avif"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="hero-enter-5 absolute bottom-3 md:bottom-8 inset-x-0 z-10 flex justify-center">
    <a href={`#${sectionId(locale, "experience")}`} class="flex flex-col items-center gap-1.5" style="text-decoration: none;">
      <span
        class="text-xs font-bold tracking-widest uppercase"
        style="color: var(--color-brand-400);">{t.hero.scroll_label}</span
      >
      <div class="bounce-y" style="color: var(--color-brand-400);">
        <Icon name="arrow-down" size={20} />
      </div>
    </a>
  </div>
</section>
