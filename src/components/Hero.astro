---
import { Image } from "astro:assets";
import perfilPhoto from "../assets/perfil_photo.jpg";
import { OWNER, SOCIAL_LINKS } from "../data/portfolio";
import { useTranslations } from "../i18n/utils";
import type { SupportedLocale } from "../i18n/utils";
import Icon from "./Icon.astro";

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const emailLink    = SOCIAL_LINKS.find((l) => l.icon === "email")!;
const linkedinLink = SOCIAL_LINKS.find((l) => l.icon === "linkedin")!;
const githubLink   = SOCIAL_LINKS.find((l) => l.icon === "github")!;
---

<section
  id="hero"
  class="relative min-h-screen overflow-hidden"
  style="padding-inline: clamp(1.25rem, 5vw, 2rem);"
>
  <!-- Top gradient: light green from top fading to base -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-72"
    style="background: linear-gradient(to bottom, oklch(72% 0.16 155 / 0.18), transparent);"
  ></div>

  <!-- Main content — centered vertically -->
  <div class="flex items-center container-max relative z-10" style="min-height: 100vh; padding-block: 5rem 5rem;">
    <div class="w-full flex flex-col-reverse md:flex-row items-center justify-between gap-12">

      <!-- Left: text -->
      <div class="flex-1 text-center sm:text-left">
        <!-- Greeting + name -->
        <h1
          class="hero-enter-1 text-hero mb-2"
          style="color: var(--color-text-primary);"
        >
          <span data-i18n="hero.greeting">{t.hero.greeting}</span>&nbsp;<span
            class="gradient-text">{OWNER.name.split(" ")[0]}</span>
        </h1>

        <!-- Role -->
        <p
          class="hero-enter-2 font-bold mb-3 gradient-text"
          style="font-size: clamp(1.35rem, 3vw, 1.75rem);"
          data-i18n="hero.role"
        >
          {t.hero.role}
        </p>

        <!-- Bio -->
        <p
          class="hero-enter-2 max-w-lg mx-auto sm:mx-0 mb-10 text-base leading-relaxed"
          style="color: var(--color-text-secondary);"
          data-i18n="hero.bio"
        >
          {t.hero.bio}
        </p>

        <!-- Social links row -->
        <div class="hero-enter-3 flex flex-wrap gap-3 justify-center sm:justify-start">
          <!-- LinkedIn -->
          <a
            href={linkedinLink.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border"
            style="border-color: var(--color-brand-500); background: oklch(58% 0.18 155 / 0.08); color: var(--color-text-primary);"
          >
            <Icon name="linkedin" size={16} />
            LinkedIn
          </a>

          <!-- GitHub -->
          <a
            href={githubLink.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border"
            style="border-color: var(--color-brand-500); background: oklch(58% 0.18 155 / 0.08); color: var(--color-text-primary);"
          >
            <Icon name="github" size={16} />
            GitHub
          </a>

          <!-- Email -->
          <a
            href={emailLink.href}
            class="social-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border"
            style="border-color: var(--color-brand-500); background: oklch(58% 0.18 155 / 0.08); color: var(--color-text-primary);"
          >
            <Icon name="email" size={16} />
            {emailLink.label}
          </a>
        </div>
      </div>

      <!-- Right: profile photo -->
      <div class="hero-enter-1 shrink-0 flex justify-center">
        <div
          class="relative w-52 h-52 md:w-64 md:h-64 rounded-full overflow-hidden"
          style="
            border: 3px solid oklch(58% 0.18 155 / 0.5);
            box-shadow: 0 0 40px oklch(58% 0.18 155 / 0.25), 0 0 0 8px oklch(58% 0.18 155 / 0.06);
          "
        >
          <Image
            src={perfilPhoto}
            alt="Johnneyre Zambrano – Front-End Developer"
            class="w-full h-full object-cover"
            loading="eager"
            width={256}
            height={256}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator — pinned at bottom center -->
  <div class="hero-enter-4 absolute bottom-8 inset-x-0 z-10 flex justify-center">
    <a
      href="#experience"
      class="flex flex-col items-center gap-1.5"
      style="text-decoration: none;"
    >
      <span
        class="text-xs font-bold tracking-widest uppercase"
        style="color: var(--color-brand-400);"
        data-i18n="hero.scroll_label"
      >{t.hero.scroll_label}</span>
      <div class="bounce-y" style="color: var(--color-brand-400);">
        <Icon name="arrow-down" size={20} />
      </div>
    </a>
  </div>
</section>
