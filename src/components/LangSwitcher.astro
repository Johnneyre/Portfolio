---
import Icon from "./Icon.astro";
// Client-side only – no locale prop needed
---

<div class="relative" id="lang-switcher">
  <button
    id="lang-toggle-btn"
    aria-label="Switch language"
    class="lang-switcher-btn flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border transition-colors duration-200"
    style="border-color: var(--color-surface-700); background: var(--color-header-buttons); color: var(--color-text-primary);"
  >
    <Icon name="globe" size={14} />
    <span id="lang-current-label" class="text-sm font-bold">ES</span>
    <span id="lang-chevron" style="transition: transform 0.2s ease; display: inline-flex;">
      <Icon name="chevron-down" size={12} />
    </span>
  </button>

  <!-- Dropdown -->
  <div
    id="lang-dropdown"
    class="lang-dropdown absolute right-0 mt-1.5 rounded-xl border shadow-xl overflow-hidden hidden"
    style="
      background: var(--color-surface-800);
      border-color: var(--color-surface-700);
      min-width: 90px;
      z-index: 100;
    "
  >
    <button
      class="lang-option w-full flex items-center justify-between px-3 py-2.5 text-sm font-bold transition-colors"
      data-lang="es"
      style="color: var(--color-text-primary);"
    >
      <span>ES</span>
      <span id="dot-es" class="w-1.5 h-1.5 rounded-full" style="background: var(--color-brand-400);"
      ></span>
    </button>
    <button
      class="lang-option w-full flex items-center justify-between px-3 py-2.5 text-sm font-bold transition-colors"
      data-lang="en"
      style="color: var(--color-text-primary);"
    >
      <span>EN</span>
      <span
        id="dot-en"
        class="w-1.5 h-1.5 rounded-full hidden"
        style="background: var(--color-brand-400);"></span>
    </button>
  </div>
</div>

<script>
  const btn = document.getElementById("lang-toggle-btn")!;
  const dropdown = document.getElementById("lang-dropdown")!;
  const chevron = document.getElementById("lang-chevron")!;
  const label = document.getElementById("lang-current-label")!;
  const dotEs = document.getElementById("dot-es")!;
  const dotEn = document.getElementById("dot-en")!;

  let isOpen = false;

  function toggleDropdown(open: boolean): void {
    isOpen = open;
    dropdown.classList.toggle("hidden", !open);
    chevron.style.transform = open ? "rotate(180deg)" : "rotate(0deg)";
  }

  function syncDots(lang: string): void {
    label.textContent = lang.toUpperCase();
    if (lang === "es") {
      dotEs.classList.remove("hidden");
      dotEn.classList.add("hidden");
    } else {
      dotEn.classList.remove("hidden");
      dotEs.classList.add("hidden");
    }
  }

  // Init from localStorage
  const savedLang = localStorage.getItem("lang") || "es";
  syncDots(savedLang);

  btn.addEventListener("click", (e) => {
    e.stopPropagation();
    toggleDropdown(!isOpen);
  });

  document.querySelectorAll<HTMLButtonElement>(".lang-option").forEach((opt) => {
    opt.addEventListener("click", () => {
      const lang = opt.dataset.lang!;
      localStorage.setItem("lang", lang);
      syncDots(lang);
      toggleDropdown(false);
      // Trigger global language switch
      window.dispatchEvent(new CustomEvent("lang-change", { detail: { lang } }));
    });
  });

  document.addEventListener("click", (e) => {
    if (!document.getElementById("lang-switcher")!.contains(e.target as Node)) {
      toggleDropdown(false);
    }
  });
</script>
