---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { PROJECT_ITEMS } from '../data/portfolio';
import { useTranslations, sectionId } from '../i18n/utils';
import type { SupportedLocale } from '../i18n/utils';
import DecorativeBlobs from './DecorativeBlobs.astro';
import Icon from './Icon.astro';
import webgpuImg from '../assets/projects/image-optimize-webgpu.png';

interface Props {
  locale: SupportedLocale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const PROJECT_IMAGES: Record<string, ImageMetadata> = {
  'image-optimize-webgpu': webgpuImg,
};

const tagLabel = (id: string) => t.skill_labels[id as keyof typeof t.skill_labels] ?? id;
---

<section
  id={sectionId(locale, 'projects')}
  class="relative section-padding overflow-hidden cv-auto"
  style="contain-intrinsic-size: auto 1600px;"
>
  <DecorativeBlobs variant="subtle" />

  <div class="container-max relative z-10">

    <div class="reveal mb-12">
      <p
        class="eyebrow text-sm font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-brand-400);"
      >
        {t.projects.label}
      </p>
      <h2 class="text-section-title" style="color: var(--color-text-primary);">
        {t.projects.title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {PROJECT_ITEMS.map((project, idx) => {
        const tItem = t.project_items[project.id as keyof typeof t.project_items];
        const image = PROJECT_IMAGES[project.id];
        const hasLinks = Boolean(project.liveUrl || project.repoUrl);
        const coverIsLink = Boolean(project.liveUrl);
        const CoverTag = coverIsLink ? 'a' : 'div';
        const coverProps = coverIsLink
          ? {
              href: project.liveUrl,
              target: '_blank',
              rel: 'noopener noreferrer',
              'aria-label': `${tItem.title} – ${t.projects.demo}`,
            }
          : {};
        return (
          <article
            class={`reveal ${idx % 2 === 0 ? 'reveal-from-left' : 'reveal-from-right'} reveal-delay-${Math.min(idx + 1, 4)} proj-card card flex flex-col`}
            style={`--accent-h: ${project.accent ?? 155}`}
          >
            <!-- Cover: framed screenshot or generated concept preview; links to the live demo when present. -->
            <CoverTag class={`proj-cover ${image ? 'proj-cover--shot' : 'proj-cover--gen'}`} {...coverProps}>
              {image ? (
                <div class="proj-shot">
                  <div class="proj-shot__bar" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <div class="proj-shot__viewport">
                    <Image
                      src={image}
                      alt={tItem.title}
                      class="proj-cover__img w-full h-full object-cover object-top"
                      width={1300}
                      height={960}
                      quality="high"
                      format="avif"
                      loading="lazy"
                    />
                  </div>
                </div>
              ) : (
                <div class="proj-gen">
                  {project.concept && (
                    <Icon name={project.concept} size={40} class="proj-gen__concept" />
                  )}
                  <span class="proj-gen__title">
                    {tItem.title}
                  </span>
                  <div class="proj-gen__logos">
                    {project.tags.map((tag) =>
                      tag.id === 'pinia' ? (
                        <Icon name="pinia" size={26} />
                      ) : tag.id === 'webgpu' ? (
                        <Icon name="webgpu" size={24} />
                      ) : (
                        <i class={tag.devicon} aria-hidden="true"></i>
                      ),
                    )}
                  </div>
                </div>
              )}
            </CoverTag>

            <div class="p-6 flex flex-col gap-4 flex-1">
              <h3 class="text-lg font-bold m-0" style="color: var(--color-text-primary);">
                {tItem.title}
              </h3>

              <div class="flex flex-col gap-3 flex-1">
                <p class="text-sm leading-relaxed m-0" style="color: var(--color-text-secondary);">
                  {tItem.description}
                </p>
                <ul class="proj-highlights">
                  {tItem.highlights.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </div>

              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="tag-chip">
                    {tag.id === 'pinia' ? (
                      <Icon name="pinia" size={18} />
                    ) : tag.id === 'webgpu' ? (
                      <Icon name="webgpu" size={16} />
                    ) : (
                      <i class={tag.devicon} aria-hidden="true"></i>
                    )}
                    {tagLabel(tag.id)}
                  </span>
                ))}
              </div>

              {hasLinks && (
                <div class="flex flex-wrap gap-3">
                  {project.liveUrl && (
                    <a
                      href={project.liveUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${tItem.title} – ${t.projects.demo}`}
                      class="social-btn social-btn--pill inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold border"
                    >
                      <Icon name="globe" size={16} aria-hidden="true" />
                      <span>{t.projects.demo}</span>
                      <Icon name="arrow-up-right" size={14} aria-hidden="true" class="ml-0.5 opacity-70" />
                    </a>
                  )}
                  {project.repoUrl && (
                    <a
                      href={project.repoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`${tItem.title} – ${t.projects.code}`}
                      class="social-btn social-btn--pill inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold border"
                    >
                      <Icon name="github" size={16} aria-hidden="true" />
                      <span>{t.projects.code}</span>
                      <Icon name="arrow-up-right" size={14} aria-hidden="true" class="ml-0.5 opacity-70" />
                    </a>
                  )}
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
