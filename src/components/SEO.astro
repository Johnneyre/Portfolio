---
import type { SupportedLocale } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";
import { SOCIAL_LINKS } from "../data/portfolio";
import { en } from "../i18n/en";

interface Props {
  locale: SupportedLocale;
  canonicalUrl?: string;
}

const { locale, canonicalUrl } = Astro.props;
const t = useTranslations(locale);

// Single source of truth for the host (trailing slash normalized away).
const siteUrl = (import.meta.env.SITE ?? "https://johnneyrez.dev").replace(/\/$/, "");
const esUrl = `${siteUrl}/`;
const enUrl = `${siteUrl}/en/`;
const currentUrl = canonicalUrl ?? (locale === "es" ? esUrl : enUrl);

const ogImage = `${siteUrl}/og-image.png`;
const ogLocale = locale === "es" ? "es_ES" : "en_US";
const ogLocaleAlternate = locale === "es" ? "en_US" : "es_ES";
const imageAlt = `${t.owner.name} – ${t.owner.role}`;

const linkedinUrl = SOCIAL_LINKS.find((l) => l.icon === "linkedin")?.href;
const githubUrl = SOCIAL_LINKS.find((l) => l.icon === "github")?.href;

// Every technology shown on the page (kept in sync via skill_labels) plus the focus areas from the bio.
const knowsAbout = [
  ...Object.values(en.skill_labels),
  "Full-Stack Web Development",
  "Web Performance Optimization",
  "Scalable Web Architecture",
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: t.owner.name,
  jobTitle: t.owner.role,
  description: t.meta.description,
  url: siteUrl,
  sameAs: [linkedinUrl, githubUrl].filter(Boolean),
  knowsAbout,
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: t.meta.title,
  description: t.meta.description,
  url: siteUrl,
  author: {
    "@type": "Person",
    name: t.owner.name,
  },
  inLanguage: locale === "es" ? "es-ES" : "en-US",
};
---

<link rel="canonical" href={currentUrl} />

<!-- Hreflang: reciprocal, distinct per-locale URLs -->
<link rel="alternate" hreflang="es" href={esUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={esUrl} />

<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
<meta name="theme-color" content="#0a0a0a" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={t.owner.name} />
<meta property="og:title" content={t.meta.title} />
<meta property="og:description" content={t.meta.description} />
<meta property="og:url" content={currentUrl} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={t.meta.title} />
<meta name="twitter:description" content={t.meta.description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={imageAlt} />

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
