---
import "../styles/global.css";
import Header from "../components/Header.astro";
import SEO from "../components/SEO.astro";
import type { SupportedLocale } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";
import { ClientRouter } from "astro:transitions";

interface Props {
  locale?: SupportedLocale;
}

const { locale = "es" } = Astro.props;
const t = useTranslations(locale);

const title = t.meta.title;
const description = t.meta.description;
---

<!doctype html>
<html lang={locale} id="html-root" class="hero-enter-on">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={t.owner.name} />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <SEO locale={locale} />

    <!-- View transitions: switch locales without a full page reload -->
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
    />

    <title>{title}</title>

    <!-- Anti-FOUC: set theme before first paint and after each view transition; route first-time visitors to their browser language. -->
    <script is:inline>
      (function () {
        const applyTheme = () =>
          document.documentElement.classList.toggle(
            "light",
            localStorage.getItem("theme") === "light",
          );
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);

        if (!localStorage.getItem("lang")) {
          const pref = (navigator.language || "").slice(0, 2).toLowerCase() === "es" ? "es" : "en";
          localStorage.setItem("lang", pref);
          const onEn = location.pathname === "/en" || location.pathname.indexOf("/en/") === 0;
          if (pref === "en" && !onEn) location.replace("/en/");
        }
      })();
    </script>
  </head>
  <body>
    <!-- Reading progress bar (scroll-driven CSS) -->
    <div id="scroll-progress"></div>

    <Header locale={locale} />

    <!-- Fixed top gradient visible through transparent header -->
    <div
      class="pointer-events-none fixed inset-x-0 top-0 z-60"
      style="height: 18rem; background: linear-gradient(to bottom, oklch(72% 0.16 155 / 0.2), transparent);"
      aria-hidden="true"
    >
    </div>

    <main>
      <slot />
    </main>

    <script>
      // Module-scoped so each re-run disconnects the prior observer.
      let revealObserver: IntersectionObserver | null = null;
      let blobObserver: IntersectionObserver | null = null;

      function setupReveal() {
        revealObserver?.disconnect();
        revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver?.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
        );
        document
          .querySelectorAll(".reveal:not(.is-visible)")
          .forEach((el) => revealObserver!.observe(el));
      }

      // Pause blob drift and the hero scroll cue while their section is off-screen.
      function setupBlobs() {
        blobObserver?.disconnect();
        blobObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              entry.target.classList.toggle("section-offscreen", !entry.isIntersecting);
            });
          },
          { rootMargin: "150px" },
        );
        document.querySelectorAll("section").forEach((s) => {
          if (s.querySelector(".blob, .blob-delay, .bounce-y")) blobObserver!.observe(s);
        });
      }

      // Fires on initial load and after every client navigation.
      document.addEventListener("astro:page-load", () => {
        setupReveal();
        setupBlobs();
      });

      // Strip the first-load flag from the incoming page so the hero entrance
      // doesn't replay over the view-transition crossfade.
      document.addEventListener("astro:before-swap", (event) => {
        (event as any).newDocument?.documentElement.classList.remove("hero-enter-on");
      });

      // On navigation, reveal everything at once so the view transition is the only animation.
      document.addEventListener("astro:after-swap", () => {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("is-visible"));
      });
    </script>
  </body>
</html>
