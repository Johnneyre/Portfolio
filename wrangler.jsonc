{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2025-09-27",
  // Sitio 100% estático: se sirve como Workers Static Assets, sin Worker SSR.
  // El HTML prerenderizado y los assets viven en ./dist (output estático de Astro).
  "assets": {
    "directory": "./dist"
  }
}
